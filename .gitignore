# ==============================================================
# VarioPro3 — .gitignore публичного репозитория
# Правило: ЛИЧНЫЕ ДАННЫЕ (записи, координаты, рабочие конфиги)
# в публикацию не попадают. Рабочие файлы остаются на диске.
# ==============================================================

# --- Python: окружение и байткод ---
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# --- Android: сборка и локальная среда ---
.gradle/
android/**/build/
app/build/
*.apk
*.aab
**/local.properties
.idea/
**/.idea/

# --- логи ---
*.log

# ==============================================================
# ЛИЧНЫЕ ДАННЫЕ АВТОРА — НЕ ПУБЛИКУЮТСЯ
# ==============================================================

# все записи датчиков, калибровки, скриншоты, звуковые профили, GPS,
# виды пульта и пр. (папка целиком; демо генерируются скриптами
# pc/make_sample_data.py и pc/make_calib_sample.py)
data/

# рабочий конфиг пульта (личная настройка; публикуется config.example.json)
config.json

# АКТИВНАЯ калибровка прибора: содержит GPS-координаты места записей,
# склонение и «отпечаток» датчиков конкретного телефона
# (публикуется pc/calibration.example.json)
pc/calibration.json

# экспортированные копии записей с применённой калибровкой
*_calibrated.csv

# (явные под-пути из ТЗ — уже покрыты правилом data/, оставлены для ясности)
data/device_profiles/
data/logs/
data/screenshots/
data/device_calibrations/

# --- генерируемые артефакты самопроверок ---
vario_proof.png

# ==============================================================
# ВНУТРЕННИЕ ЗАМЕТКИ / ПЛАНЫ / ОТЧЁТЫ — НЕ ПУБЛИКУЮТСЯ
# ==============================================================
CLAUDE.md
docs/todo_pack*.md
docs/report_pack*.md
docs/README_old_phase0.md

# ==============================================================
# СКРИНШОТЫ приложения/экрана — НЕ ПУБЛИКУЮТСЯ.
# Функциональные ассеты (логотип assets/*.png, иконки Android
# res/mipmap/*, векторные drawable) под это правило НЕ попадают.
# ==============================================================
docs/*.png

# ==============================================================
# ВСЯ ДОКУМЕНТАЦИЯ .md — НЕ ПУБЛИКУЕТСЯ, КРОМЕ корневого README.md.
# Правило ловит .md в любой папке (docs/, android/ и пр.);
# ведущий слэш у исключения анкерит РОВНО корневой README.md
# (android/README.md и прочие README под правило попадают).
# ==============================================================
*.md
!/README.md
